define BASH_FUNC_module%%
() {  _mlshopt="f";
 case "$-" in 
 *f*)
 unset _mlshopt
 ;;
 esac;
 if [ -n "${_mlshopt:-}" ]; then
 set -$_mlshopt;
 fi;
 eval $($LMOD_CMD bash "$@") && eval $(${LMOD_SETTARG_CMD:-:} -s sh);
 if [ -n "${_mlshopt:-}" ]; then
 set +$_mlshopt;
 fi;
 unset _mlshopt
}
endef
